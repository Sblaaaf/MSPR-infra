KCAL_SECRET_TOKEN=clesecrete
KCAL_SERVICE_URL=http://kcal:8001
MEAL_SERVICE_URL=http://meal:8003
AUTH_SERVICE_URL=http://auth:8004

# Recommendation service
RECOMMENDATION_API_KEY=change-me-in-production
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=recommendation_db
CORS_ORIGINS=*

# HUGGINGFACE API - "sblaaaf_mspr_healthaicoach"
HF_TOKEN=your_huggingface_token_here

# Vision (photo recognition) — Phase 1: huggingface (free). Switch to "claude" in Phase 2 with ANTHROPIC_API_KEY.
VISION_PROVIDER=huggingface
VISION_MODEL=Salesforce/blip-image-captioning-large
VISION_MONTHLY_CAP=5000
VISION_MAX_IMAGE_PX=768

# Anthropic API (for Claude vision). Leave empty to fallback to HuggingFace.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Kaggle credentials (for ETL data downloads)
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here
